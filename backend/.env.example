# OpenTap Backend Configuration
# Copy to .env and fill in your values

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opentap
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/opentap

# Auth
SECRET_KEY=change-me-run-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# SMS (Twilio) — leave blank to disable SMS reporting
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Photo Storage (Cloudflare R2 / S3-compatible)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=opentap-photos
STORAGE_PUBLIC_URL=

# Report Lifecycle
STALE_THRESHOLD_DAYS=14

# Rate Limiting
RATE_LIMIT_REPORTS_PER_HOUR=10
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Internal API Key (for cron jobs)
INTERNAL_API_KEY=change-me-internal-key

# App
DEBUG=true
